    "@openzeppelin/contracts": "^5.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.8.6",
    "@nomicfoundation/hardhat-toolbox": "hh2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
